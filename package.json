{
  "name": "tex-machina",
  "publisher": "Tony29028",
  "displayName": "TeX-Machina",
  "description": "Interactive LaTeX assistant with symbolic computation, plotting, and bibliography management.",
  "version": "0.1.9",
  "repository": {
    "type": "git",
    "url": "https://github.com/tony10486/Tex-Machina"
  },
  "license": "MIT",
  "keywords": [
    "latex",
    "math",
    "sympy",
    "plotting",
    "bibtex",
    "oeis"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:latex"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "TeX-Machina",
      "properties": {
        "tex-machina.laplace.sourceVariable": {
          "type": "string",
          "default": "t",
          "description": "라플라스 변환의 기본 소스 변수 (예: t)"
        },
        "tex-machina.laplace.targetVariable": {
          "type": "string",
          "default": "s",
          "description": "라플라스 변환의 결과 대상 변수 (예: s)"
        },
        "tex-machina.angleUnit": {
          "type": "string",
          "enum": [
            "deg",
            "rad"
          ],
          "default": "deg",
          "description": "회전변환 시 각도의 기본 단위. (deg: 도, rad: 라디안)"
        },
        "tex-machina.plot.datDensity": {
          "type": "integer",
          "default": 500,
          "minimum": 10,
          "maximum": 5000,
          "description": "2D PGFPlots .dat 파일 생성 시 계산할 점의 개수 (밀도)"
        },
        "tex-machina.plot.yMultiplier": {
          "type": "number",
          "default": 5.0,
          "minimum": 1.0,
          "maximum": 50.0,
          "description": "2D 그래프 데이터(.dat) 생성 시 y축 표시 범위를 넘어서 계산할 배수 (Clipping Limit)"
        },
        "tex-machina.plot.lineColor": {
          "type": "string",
          "default": "blue",
          "description": "2D PGFPlots 그래프의 기본 선 색상 (예: blue, red, black, cyan!50!blue)"
        },
        "tex-machina.autoBracing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "스마트 첨자 자동 괄호 (Auto-bracing for Sub/Superscripts) 기능을 활성화합니다. _나 ^ 뒤에 두 글자 이상 입력 시 자동으로 {}로 묶어줍니다."
        },
        "tex-machina.markdownLatex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "마크다운 스타일 자동 변환 기능을 활성화합니다. **텍스트** + 스페이스는 \\textbf{텍스트}로, - + 스페이스는 itemize 환경으로 변환됩니다."
        },
        "tex-machina.smartQuotes.enabled": {
          "type": "boolean",
          "default": true,
          "description": "LaTeX 스마트 따옴표 기능을 활성화합니다. \" 키를 누르면 상황에 맞게 `` 또는 ''로 변환됩니다."
        },
        "tex-machina.mathNav.enabled": {          "type": "boolean",
          "default": false,
          "description": "수식 계층별 점프 모드 (Math Navigation Mode) 기능을 활성화합니다. 활성화 시 Alt+방향키로 수식 내 주요 슬롯 사이를 점프할 수 있습니다."
        },
        "tex-machina.mathNav.selectContent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "수식 점프 시 슬롯(괄호) 내 내용이 있다면 자동으로 선택(Selection)합니다."
        },
        "tex-machina.splitMath.atPlus": {
          "type": "boolean",
          "default": false,
          "description": "수식 자동 분할 시 등호(=) 뿐만 아니라 덧셈/뺄셈(+, -) 기호에서도 줄바꿈을 허용합니다."
        },
        "tex-machina.cli.chainDelimiter": {
          "type": "string",
          "enum": [
            "&&",
            "//",
            "|",
            "&"
          ],
          "default": "&&",
          "description": "명령어 체이닝을 위한 구분자를 설정합니다. (기본값: &&)"
        },
        "tex-machina.macros.customContexts": {
          "type": "array",
          "title": "사용자 정의 매크로 컨텍스트",
          "markdownDescription": "### 🛠 매크로 컨텍스트 설정 가이드\n커서가 특정 환경(주석, 코드 등)에 있을 때만 작동하는 매크로를 정의합니다.\n- **사용법**: 매크로 정의 시 `이름:컨텍스트` 형태로 등록 (예: `;abc:comment`)\n- **편의 기능**: [자주 쓰이는 컨텍스트 세트 추가하기](command:tex-machina.addContextShortcut)",
          "items": {
            "type": "object",
            "title": "컨텍스트 항목",
            "properties": {
              "name": {
                "type": "string",
                "title": "컨텍스트 이름",
                "description": "매크로 호출 시 사용할 이름 (예: comment)",
                "pattern": "^[a-zA-Z0-9_-]+$",
                "errorMessage": "영문, 숫자, -, _ 만 사용 가능합니다."
              },
              "regex": {
                "type": "string",
                "title": "감지용 정규표현식",
                "description": "해당 영역을 판별할 Regex (예: ^\\s*%.*)"
              },
              "scope": {
                "type": "string",
                "title": "검사 범위",
                "enum": [
                  "line",
                  "around"
                ],
                "default": "line",
                "enumDescriptions": [
                  "현재 줄만 검사 (성능 위주)",
                  "전후 2줄 포함 총 5줄 검사 (멀티라인 환경용)"
                ]
              }
            },
            "required": [
              "name",
              "regex"
            ]
          },
          "default": [
            {
              "name": "comment",
              "regex": "^\\s*%.*",
              "scope": "line"
            }
          ]
        },
        "tex-machina.labelVisualization.physics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "라벨 시각화에서 물리 엔진 애니메이션을 활성화합니다."
        },
        "tex-machina.labelVisualization.physics.solver": {
          "type": "string",
          "enum": [
            "barnesHut",
            "forceAtlas2Based",
            "repulsion",
            "hierarchicalRepulsion"
          ],
          "default": "forceAtlas2Based",
          "description": "물리 엔진 솔버를 선택합니다."
        },
        "tex-machina.labelVisualization.physics.gravitationalConstant": {
          "type": "number",
          "default": -80,
          "description": "중력 상수 (값이 작을수록 노드 간의 척력이 강해집니다)."
        },
        "tex-machina.labelVisualization.physics.springLength": {
          "type": "number",
          "default": 80,
          "description": "스프링의 기본 길이."
        },
        "tex-machina.labelVisualization.physics.springConstant": {
          "type": "number",
          "default": 0.04,
          "description": "스프링 상수 (값이 클수록 스프링이 팽팽해집니다)."
        },
        "tex-machina.labelVisualization.physics.avoidOverlap": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "description": "노드 겹침 방지 강도 (0~1)."
        },
        "tex-machina.labelVisualization.physics.stabilizationIterations": {
          "type": "integer",
          "default": 150,
          "description": "초기 안정화 반복 횟수."
        },
        "tex-machina.labelVisualization.node.baseSize": {
          "type": "number",
          "default": 12,
          "description": "노드의 기본 크기."
        },
        "tex-machina.labelVisualization.node.spacing": {
          "type": "number",
          "default": 80,
          "description": "노드 간의 간격 (스프링 길이)."
        },
        "tex-machina.labelVisualization.physics.stabilizationFinish": {
          "type": "string",
          "enum": [
            "none",
            "fit",
            "disablePhysics"
          ],
          "default": "none",
          "enumDescriptions": [
            "아무것도 하지 않음",
            "화면에 맞게 크기 조절 (Fit View)",
            "물리 엔진 비활성화"
          ],
          "description": "애니메이션(안정화) 종료 후 처리 방식."
        }
      }
    },
    "commands": [
      {
        "command": "tex-machina.addContextShortcut",
        "title": "LaTeX: Add Common Macro Contexts"
      },
      {
        "command": "tex-machina.openCLI",
        "title": "Open TeX-Machina CLI"
      },
      {
        "command": "tex-machina.analyzeWidth",
        "title": "LaTeX: Analyze Formula Width"
      },
      {
        "command": "tex-machina.escapeAutoBracing",
        "title": "LaTeX: Escape Auto-bracing"
      },
      {
        "command": "tex-machina.splitMath",
        "title": "LaTeX: Auto-split Math Formula"
      },
      {
        "command": "tex-machina.formatUnit",
        "title": "LaTeX: Format Unit (siunitx)"
      },
      {
        "command": "tex-machina.insertTable",
        "title": "LaTeX: Insert Table"
      },
      {
        "command": "tex-machina.insertScanPrevention",
        "title": "LaTeX: Insert Scan Prevention Pattern"
      },
      {
        "command": "tex-machina.addHat",
        "title": "LaTeX: Add Hat Diacritic (\\hat{})"
      },
      {
        "command": "tex-machina.addTilde",
        "title": "LaTeX: Add Tilde Diacritic (\\tilde{})"
      },
      {
        "command": "tex-machina.addDot",
        "title": "LaTeX: Add Dot Diacritic (\\dot{})"
      },
      {
        "command": "tex-machina.deleteUnusedLabels",
        "title": "LaTeX: Delete Unused Labels"
      },
      {
        "command": "tex-machina.toggleMathNav",
        "title": "LaTeX: Toggle Formula Node Navigation"
      },
      {
        "command": "tex-machina.mathNavRight",
        "title": "LaTeX: Math Node Navigation Right"
      },
      {
        "command": "tex-machina.mathNavLeft",
        "title": "LaTeX: Math Node Navigation Left"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tex-machina-explorer",
          "title": "TeX-Machina",
          "icon": "$(edit)"
        }
      ]
    },
    "views": {
      "tex-machina-explorer": [
        {
          "type": "webview",
          "id": "tex-machina.preview",
          "name": "Math Preview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tex-machina.openCLI",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;",
        "when": "editorTextFocus"
      },
      {
        "command": "tex-machina.escapeAutoBracing",
        "key": "escape",
        "when": "editorTextFocus && editorLangId == 'latex' && !suggestWidgetVisible && !findWidgetVisible && !parameterHintsVisible && !editorHasSelection && !inSnippetMode"
      },
      {
        "command": "tex-machina.splitMath",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.formatUnit",
        "key": "ctrl+shift+' u",
        "mac": "cmd+shift+' u",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.addHat",
        "key": "alt+shift+6",
        "mac": "alt+shift+6",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.addTilde",
        "key": "alt+shift+`",
        "mac": "alt+shift+`",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.addDot",
        "key": "alt+.",
        "mac": "alt+.",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.toggleMathNav",
        "key": "ctrl+shift+' l",
        "mac": "cmd+shift+' l",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.mathNavRight",
        "key": "alt+right",
        "mac": "alt+right",
        "when": "editorTextFocus && editorLangId == 'latex'"
      },
      {
        "command": "tex-machina.mathNavLeft",
        "key": "alt+left",
        "mac": "alt+left",
        "when": "editorTextFocus && editorLangId == 'latex'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:fast": "vscode-test --run out/test/parser.test.js out/test/mathSplitter.test.js out/test/unitExpander.test.js out/test/macro.test.js out/test/table.test.js out/test/smartSearch.test.js",
    "test:integration": "vscode-test --run out/test/autoBracing.test.js out/test/markdown.test.js out/test/smartQuotes.test.js out/test/diacritics.test.js out/test/labelDetection.test.js out/test/labelDiscovery.test.js out/test/nodeNavigation.test.js",
    "test:webview": "vscode-test --run out/test/webview.test.js",
    "test:perf": "vscode-test --run out/test/performance.test.js out/test/extreme.test.js",
    "test:only": "vscode-test --run"
  },
  "dependencies": {
    "mathjax-full": "^3.2.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
